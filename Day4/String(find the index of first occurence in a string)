class Solution {
    public int strStr(String haystack, String needle) {
        int val=-1;
        int last=haystack.length()-needle.length();
        for(int i=0;i<=haystack.length();i++)
        {
            if(i<=last&&needle.equals(haystack.substring(i,i+needle.length())))
            {
                val=i;
                break;
            }
        }
    return val;
        
    }
}
